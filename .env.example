# BMFC Club Hub — copy to .env.local

# Supabase (separate club hub project — name + 4-digit passcode auth)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Use live Supabase data instead of mock (omit or leave unset for mock mode)
VITE_CLUB_DATA_SOURCE=supabase

# Service role key — scripts only (npm run sync:ddsfl). Never prefix with VITE_
# Supabase Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# Web push — generate with: npm run generate:vapid-keys
VITE_VAPID_PUBLIC_KEY=

# Server-only (Supabase Edge Function secrets — do NOT prefix with VITE_)
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:your@email.com
