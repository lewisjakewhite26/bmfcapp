  "dependencies": {
    "@supabase/supabase-js": "^2.49.1",
    "framer-motion": "^12.4.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.5.2",
    "react-router-dom": "^7.2.0"
