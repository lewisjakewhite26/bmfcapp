    "jsdom": "^29.1.1",
    "playwright": "^1.52.0",
    "postcss": "^8.5.3",
    "sharp": "^0.35.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.4",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.24.1",
    "vite": "^6.2.0",
    "vite-plugin-pwa": "^1.3.0",
